# ── Binance ──
# Solo lectura para empezar (no necesario para ticker público).
# Para ejecutar trades en live, generar API key con permisos de Spot trading.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Anthropic (Claude Sonnet 4.6) ──
ANTHROPIC_API_KEY=

# ── Telegram ──
# Crea un bot con @BotFather, copia el token aquí.
# Para el chat_id, envía /start a tu bot y consulta:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Modo ──
# paper | testnet | live  (default: paper)
AI_TRADER_MODE=paper

# Doble lock para activar operativa real. Sin esto, --mode live falla.
# Solo poner "yes" cuando estés ABSOLUTAMENTE seguro de operar con dinero real.
AI_TRADER_ALLOW_LIVE=

# ── Logs ──
AI_TRADER_LOG_DIR=C:/LogsTraiding/ai-trader
AI_TRADER_LOG_LEVEL=INFO
