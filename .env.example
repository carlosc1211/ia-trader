# ── Binance ──
# Credenciales separadas por entorno para evitar mezclar testnet con live.
# El bot elige el par correcto según --mode.
#
# Testnet (https://testnet.binance.vision — dinero ficticio):
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
#
# Live (binance.com — DINERO REAL). NO marcar Withdrawals. Activar IP whitelist.
BINANCE_LIVE_API_KEY=
BINANCE_LIVE_API_SECRET=
#
# Fallback genérico (opcional, retrocompatibilidad). Si las específicas
# existen, estas se ignoran. Dejar vacías si usas las _TESTNET_/_LIVE_.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Anthropic (Claude Sonnet 4.6) ──
ANTHROPIC_API_KEY=

# ── Telegram ──
# Crea un bot con @BotFather, copia el token aquí.
# Para el chat_id, envía /start a tu bot y consulta:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Modo ──
# paper | testnet | live  (default: paper)
AI_TRADER_MODE=paper

# Doble lock para activar operativa real. Sin esto, --mode live falla.
# Solo poner "yes" cuando estés ABSOLUTAMENTE seguro de operar con dinero real.
AI_TRADER_ALLOW_LIVE=

# ── Logs ──
AI_TRADER_LOG_DIR=C:/LogsTraiding/ai-trader
AI_TRADER_LOG_LEVEL=INFO
